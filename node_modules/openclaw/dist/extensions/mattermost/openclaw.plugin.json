          "actions": {
            "type": "object",
            "properties": {
              "reactions": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "commands": {
            "type": "object",
            "properties": {
              "native": {
                "anyOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "string",
                    "const": "auto"
                  }
                ]
              },
              "nativeSkills": {
                "anyOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "string",
                    "const": "auto"
                  }
                ]
              },
              "callbackPath": {
                "type": "string"
              },
              "callbackUrl": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "interactions": {
            "type": "object",
            "properties": {
              "callbackBaseUrl": {
                "type": "string"
              },
              "allowedSourceIps": {
                "type": "array",
