          "network": {
            "type": "object",
            "properties": {
              "dangerouslyAllowPrivateNetwork": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "dmChannelRetry": {
            "type": "object",
            "properties": {
              "maxRetries": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10
              },
              "initialDelayMs": {
                "type": "integer",
                "minimum": 100,
                "maximum": 60000
              },
              "maxDelayMs": {
                "type": "integer",
                "minimum": 1000,
                "maximum": 60000
              },
              "timeoutMs": {
                "type": "integer",
                "minimum": 5000,
                "maximum": 120000
              }
