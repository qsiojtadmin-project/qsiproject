# Example .env for connecting backend to Supabase/Postgres
# Replace the values with the connection string from your Supabase project (Settings → Database → Connection string)
# Option A: single DATABASE_URL (recommended)
# DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>?sslmode=require

# Option B: separate DB_* values
# DB_HOST=<DB_HOST>
# DB_PORT=5432
# DB_NAME=<DB_NAME>
# DB_USER=<DB_USER>
# DB_PASSWORD=<DB_PASSWORD>
# DB_SSL=true

# JWT secret used for local auth (change for production)
# JWT_SECRET=change_this_secret

# Example (do NOT commit credentials):
# DATABASE_URL=postgresql://postgres:mysecret@db.abcd1234.supabase.co:5432/postgres?sslmode=require
